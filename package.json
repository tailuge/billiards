{
  "name": "billiards",
  "description": "Billiards",
  "version": "0.3.1",
  "author": "tailuge",
  "homepage": "https://github.com/tailuge",
  "keywords": [
    "billiards",
    "snooker",
    "threejs",
    "swc",
    "physics"
  ],
  "license": "GPL-3.0",
  "sideEffects": false,
  "packageManager": "yarn@4.9.1",
  "scripts": {
    "test": "jest --config ./test/jest.config.js --verbose --silent",
    "coverage": "jest --config ./test/jest.config.js --coverage --silent",
    "version-gen": "node -e \"const d=new Date();const v=d.getFullYear().toString().slice(-2)+('0'+(d.getMonth()+1)).slice(-2)+('0'+d.getDate()).slice(-2)+'.'+('0'+d.getHours()).slice(-2);require('fs').writeFileSync('src/utils/version.ts', 'export const VERSION = \\'' + v + '\\';\\n')\"",
    "dev": "webpack",
    "build": "npm run version-gen && webpack",
    "lint": "tsc --noEmit && eslint .",
    "lint:css": "stylelint \"dist/**/*.{css,html}\"",
    "prettify": "prettier --cache true --write --trailing-comma es5 --no-semi {src,test}/**/*.[jt]s dist/**/*.{css,html} *.[jt]s *.json",
    "markdownlint": "npx markdownlint-cli2 README.md --fix",
    "serve": "concurrently \"npm run watch\" \"npm run start-server\"",
    "start-server": "http-server dist -p 8080 -c-1",
    "watch": "webpack --watch",
    "deps": "npx yarn-check --skip-unused",
    "gltfpack": "npx gltfpack -i dist/models/p8.gltf -o dist/models/p8.min.gltf && npx gltfpack -i dist/models/threecushion.gltf -o dist/models/threecushion.min.gltf && npx gltfpack -i dist/models/snooker.gltf -o dist/models/snooker.min.gltf && npx gltfpack -i dist/models/d-snooker.gltf -o dist/models/d-snooker.min.gltf"
  },
  "dependencies": {
    "@tailuge/messaging": "1.18.0",
    "interactjs": "1.10.27",
    "jsoncrush": "^1.1.8",
    "three": "0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@swc/core": "1.15.33",
    "@swc/jest": "0.2.39",
    "@testing-library/dom": "10.4.1",
    "@types/chai": "5.2.3",
    "@types/jest": "30.0.0",
    "@types/node": "25.6.0",
    "@types/three": "0.184.0",
    "canvas": "3.2.3",
    "chai": "6.2.2",
    "concurrently": "^9.2.1",
    "eslint": "10.3.0",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-sonarjs": "4.0.3",
    "http-server": "^14.1.1",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "node-notifier": "^10.0.1",
    "postcss-html": "^1.8.1",
    "prettier": "3.8.3",
    "stylelint": "17.10.0",
    "stylelint-config-standard": "^40.0.0",
    "swc-loader": "0.2.7",
    "ts-jest": "29.4.9",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "webpack": "5.106.2",
    "webpack-cli": "7.0.2",
    "webpack-dev-server": "5.2.3"
  }
}
